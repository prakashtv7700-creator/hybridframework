<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <File name="FileLogger" fileName="logs/Automation.log">
            <PatternLayout pattern="%d %-5p %c - %m%n"/>
        </File>

        <Console name="Console">
            <PatternLayout pattern="%d %-5p %c - %m%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="FileLogger"/>
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>